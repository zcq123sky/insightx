{
  "name": "insightx",
  "description": "A barebones Turborepo example for working with Task Graphs.",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "turbo": "^2.7.6"
  },
  "packageManager": "bun@1.3.6",
  "scripts": {
    "dev": "turbo run dev",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
